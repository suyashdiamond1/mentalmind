# Copy this file to `.env.local` and fill in your Supabase credentials.
# Do NOT commit your real keys to version control.

# Your Supabase project URL (from Supabase Dashboard → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Your Supabase anon/public key (from Supabase Dashboard → Settings → API)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Optional: If you prefer to test the dev server without creating a file,
# you can set the vars in PowerShell for the current session:
#   $env:NEXT_PUBLIC_SUPABASE_URL = 'https://your-project.supabase.co'
#   $env:NEXT_PUBLIC_SUPABASE_ANON_KEY = 'eyJ...'
